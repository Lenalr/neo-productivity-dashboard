generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String                @id @default(cuid())
  name                String
  email               String                @unique
  role                String
  team                String
  avatar              String?
  active              Boolean               @default(true)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  ownedProjects       Project[]             @relation("ProjectOwner")
  assignedTasks       Task[]                @relation("TaskAssignee")
  assignedSubtasks    Subtask[]             @relation("SubtaskAssignee")
  notes               TaskNote[]
  productivityEntries ProductivitySnapshot[]
}

model Project {
  id          String      @id @default(cuid())
  title       String      @unique
  description String
  status      String
  priority    String
  startDate   DateTime?
  dueDate     DateTime?
  ownerId     String?
  imported    Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  owner       User?       @relation("ProjectOwner", fields: [ownerId], references: [id])
  tasks       Task[]
  importJobs  ImportJob[]
}

model Task {
  id             String     @id @default(cuid())
  title          String
  description    String
  status         String
  priority       String
  dueDate        DateTime?
  estimatedHours Int        @default(0)
  completedAt    DateTime?
  projectId      String?
  assigneeId     String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  project        Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignee       User?      @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  subtasks       Subtask[]
  notes          TaskNote[]
}

model Subtask {
  id         String    @id @default(cuid())
  title      String
  status     String
  assigneeId String?
  taskId     String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  assignee   User?     @relation("SubtaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  task       Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model TaskNote {
  id        String   @id @default(cuid())
  body      String
  taskId    String
  authorId  String
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model ImportJob {
  id              String   @id @default(cuid())
  sourceName      String
  sourcePath      String
  projectId       String?
  rowsDetected    Int
  tasksCreated    Int
  subtasksCreated Int
  status          String
  summary         String
  importedAt      DateTime @default(now())
  project         Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model ProductivitySnapshot {
  id             String   @id @default(cuid())
  date           DateTime
  score          Int
  completionRate Int
  overdueRate    Int
  backlogCount   Int
  summary        String
  userId         String?
  createdAt      DateTime @default(now())
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}
